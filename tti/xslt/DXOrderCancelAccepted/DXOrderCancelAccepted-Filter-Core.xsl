<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet exclude-result-prefixes="b c batch multibatch" version="1.0"     xmlns="http://www.odcgroup.com/Request"
    xmlns:a="http://www.odcgroup.com/Request" xmlns:b="http://www.temenos.com/T24/event/TTI/DXOrderReturn"
                xmlns:batch="http://www.temenos.com/T24/event/TTI/BatchDXOrderReturn" xmlns:c="http://www.temenos.com/T24/event/TTI/MultiDXOrderReturn" xmlns:infra="http://www.odcgroup.com/InfraPMS"
                xmlns:multibatch="http://www.temenos.com/T24/event/TTI/BatchMultiDXOrderReturn" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<!-- START of protected area  -->
	<!-- Do not change ! -->
	<xsl:template match="@* | node()">
		<xsl:copy>
			<xsl:apply-templates select="@* | node()"/>
		</xsl:copy>
	</xsl:template>

	<!-- END of protected area  -->
	<!-- Condition 1 -->
	<xsl:template match="b:DXOrderReturn">
		<xsl:apply-templates select="self::b:DXOrderReturn[b:memoAccountList/b:memoAccount = 'NO']" mode="filter1"/>
	</xsl:template>
	<!-- Condition 2 -->
	<xsl:template match="b:DXOrderReturn" mode="filter1">
		<xsl:apply-templates select="self::b:DXOrderReturn[not(b:dealerBookList/b:dealerBook)]" mode="filter2"/>
	</xsl:template>
	<!-- Condition 3 -->
	<xsl:template match="b:DXOrderReturn" mode="filter2">
		<xsl:apply-templates select="self::b:DXOrderReturn[b:customerTypeCustomerSecurityJoinGroup[@index = '1']/b:customerTypeCustomerSecurityJoinList/b:customerTypeCustomerSecurityJoin = 'CUSTOMER']" mode="filter3"/>
	</xsl:template>
	<!-- Condition 4 -->
	<!--<xsl:template match="b:DXOrderReturn" mode="filter3">
		<xsl:apply-templates select="self::b:DXOrderReturn[substring(b:tapRefId,1,1) = 'I']" mode="filter4"/>
	</xsl:template>-->
	<!-- Condition 5 -->
	<xsl:template match="b:DXOrderReturn" mode="filter3">
		<xsl:apply-templates select="self::b:DXOrderReturn[(b:orderStatus = 'CANCELLED' and ../../c:PreviousEvent/b:DXOrderReturn/b:orderStatus = 'CANCELLATION REQUEST') or (b:orderStatus = 'FILLED' and ../../c:PreviousEvent/b:DXOrderReturn/b:orderStatus = 'CANCELLATION REQUEST')]" mode="filter4"/>
	</xsl:template>

	<xsl:template match="b:DXOrderReturn" mode="filter4">
		<xsl:apply-templates select="self::b:DXOrderReturn[((b:parent = 'NO' or b:parent ='' or not(b:parent)) and b:parentChildRef !='') or (not(b:parent) and not(b:parentChildRef))]" mode="filter-custo"/>
	</xsl:template>

	<!-- Custo placeholder -->



	<xsl:template match="b:DXOrderReturn" mode="filter-custo">
		<xsl:apply-templates select="self::b:DXOrderReturn" mode="filter-final"/>
	</xsl:template>

	<!-- Copy block -->
	<xsl:template match="b:DXOrderReturn" mode="filter-final">
		<xsl:copy>
			<xsl:apply-templates select="@* | node()"/>
		</xsl:copy>
	</xsl:template>
