<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet exclude-result-prefixes="b c batch multibatch" version="1.0" 
	xmlns="http://www.odcgroup.com/F2B" 
	xmlns:b="http://www.temenos.com/T24/event/TTI/T24AFBStatusChange" 
	xmlns:batch="http://www.temenos.com/T24/event/TTI/BatchT24AFBStatusChange" 
    xmlns:c="http://www.temenos.com/T24/event/TTI/MultiT24AFBStatusChange" 
    xmlns:infra="http://www.odcgroup.com/InfraPMS" 
    xmlns:multibatch="http://www.temenos.com/T24/event/TTI/BatchMultiT24AFBStatusChange"
                xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<!-- START of protected area  -->
	<!-- Do not change ! -->
	<xsl:template match="@* | node()">
		<xsl:copy>
			<xsl:apply-templates select="@* | node()"/>
		</xsl:copy>
	</xsl:template>
	<!-- END of protected area  -->
	<!-- Condition 1 -->
	<xsl:template match="b:T24AFBStatusChange">
		<xsl:apply-templates select="self::b:T24AFBStatusChange[b:memoSecAccMasterJoinList/b:memoSecAccMasterJoin = 'NO']" mode="filter1"/>
	</xsl:template>
	<!-- Condition 2 -->
	<xsl:template match="b:T24AFBStatusChange" mode="filter1">
		<xsl:apply-templates select="self::b:T24AFBStatusChange[not(b:dealerSecAccMasterJoinList/b:dealerSecAccMasterJoin)]" mode="filter2"/>
	</xsl:template>
	<!-- Condition 3 -->
	<xsl:template match="b:T24AFBStatusChange" mode="filter2">
		<xsl:apply-templates select="self::b:T24AFBStatusChange[b:customerTypeCustomerSecurityJoinGroup/b:customerTypeCustomerSecurityJoinList/b:customerTypeCustomerSecurityJoin = 'CUSTOMER']" mode="filter3"/>
	</xsl:template>
	<!-- Condition 4 -->
	<xsl:template match="b:T24AFBStatusChange" mode="filter3">
		<xsl:apply-templates select="self::b:T24AFBStatusChange[b:SubAssetTypeSecurityMasterJoin and contains($list_SubAssetType_T24AFBStatusChange,b:SubAssetTypeSecurityMasterJoin)]" mode="filter4"/>
	</xsl:template>
	<!-- Condition 5 -->
	<xsl:template match="b:T24AFBStatusChange" mode="filter4">
		<xsl:apply-templates select="self::b:T24AFBStatusChange[b:dealStatus = 'TRANSMITTED' or b:dealStatus = 'CANCELLED']" mode="filter5"/>
	</xsl:template>
	<!-- Condition 6 -->
	<xsl:template match="b:T24AFBStatusChange" mode="filter5">
		<xsl:apply-templates select="self::b:T24AFBStatusChange[b:orderStatus = 'ACKNOWLEDGED']" mode="filter6"/>
	</xsl:template>
	<!-- Condition 7-->
	<xsl:template match="b:T24AFBStatusChange" mode="filter6">
		<xsl:apply-templates select="self::b:T24AFBStatusChange[b:afbRefId and b:afbRefId != '']" mode="filter7"/>
	</xsl:template>
	<!-- Condition 8 -->
	<xsl:template match="b:T24AFBStatusChange" mode="filter7">
		<xsl:apply-templates select="self::b:T24AFBStatusChange[b:parent = 'NO' or not(b:parent)]" mode="filter8"/>
	</xsl:template>
	<!-- Condition 9 -->
	<xsl:template match="b:T24AFBStatusChange" mode="filter8">
		<xsl:apply-templates select="self::b:T24AFBStatusChange[not(b:dealStatus = ../../c:PreviousEvent/b:T24AFBStatusChange/b:dealStatus)]" mode="filter9"/>
	</xsl:template>
	<!-- Condition 10 -->
	<xsl:template match="b:T24AFBStatusChange" mode="filter9">
		<xsl:apply-templates select="self::b:T24AFBStatusChange[starts-with(b:tapRefId,'I')]" mode="filter-custo"/>
	</xsl:template>
	<!-- Custo placeholder -->
	<xsl:template match="b:T24AFBStatusChange" mode="filter-custo">
		<xsl:apply-templates select="self::b:T24AFBStatusChange" mode="filter-final"/>
	</xsl:template>

	<!-- Copy block -->
	<xsl:template match="b:T24AFBStatusChange" mode="filter-final">
		<xsl:copy>
			<xsl:apply-templates select="@* | node()"/>
		</xsl:copy>
	</xsl:template>
