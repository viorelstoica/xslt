<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns="http://www.odcgroup.com/PositionPMS" xmlns:ns0="http://www.temenos.com/T24/event/Common/EventCommon" xmlns:b="http://www.temenos.com/T24/event/TTI/CashPosition" xmlns:batch="http://www.temenos.com/T24/event/TTI/BatchCashPosition" xmlns:c="http://www.temenos.com/T24/event/TTI/MultiCashPosition" xmlns:infra="http://www.odcgroup.com/InfraPMS" xmlns:multibatch="http://www.temenos.com/T24/event/TTI/BatchMultiCashPosition" exclude-result-prefixes="b c batch multibatch ns0" version="1.0">
   <xsl:output encoding="UTF-8" indent="yes" method="xml"/>
   <xsl:template match="c:MultiCashPosition">
      <xsl:apply-templates select="c:CurrentEvent/b:CashPosition"/>
   </xsl:template>
   <xsl:template match="batch:BatchCashPosition">
      <xsl:element xmlns="http://www.temenos.com/T24/event/TTI/BatchCashPosition" name="BatchCashPosition">
         <xsl:apply-templates select="b:CashPosition"/>
      </xsl:element>
   </xsl:template>
   <xsl:template match="multibatch:BatchMultiCashPosition">
      <xsl:element xmlns="http://www.temenos.com/T24/event/TTI/BatchMultiCashPosition" name="BatchMultiCashPosition">
         <xsl:apply-templates select="c:MultiCashPosition"/>
      </xsl:element>
   </xsl:template>
   <xsl:template match="b:CashPosition">
      <PositionPMS>
         <xsl:attribute name="mode">INSUPD</xsl:attribute>
         <xsl:attribute name="output">
            <xsl:value-of select="concat('cashPosition',b:id)"/>
         </xsl:attribute>
         <DataGroup>
            <CashPosition>
               <xsl:attribute name="description">
                  <xsl:value-of select="concat('CashPosition.xsl+', name(/*), '+', b:eventCommon/ns0:eventId, '+', b:eventCommon/ns0:creationTime)"/>
               </xsl:attribute>
               <xsl:attribute name="sequenceNumber">
                  <xsl:call-template name="calcSeqNum">
                     <xsl:with-param name="creationTime">
                        <xsl:value-of select="b:eventCommon/ns0:creationTime"/>
                     </xsl:with-param>
                  </xsl:call-template>
               </xsl:attribute>
               <xsl:call-template name="balance"/>
               <xsl:call-template name="cashAccount"/>
               <xsl:call-template name="historicalExchangeRate"/>
               <xsl:call-template name="initialLoadDate"/>
               <xsl:call-template name="portfolio"/>
               <xsl:call-template name="positionCode"/>
               <xsl:call-template name="positionCurrency"/>
               <xsl:call-template name="sourceCode"/>
               <xsl:call-template name="status"/>
               <xsl:call-template name="type"/>
               <xsl:call-template name="valueDate"/>
               <xsl:call-template name="userDefinedField"/>
               <xsl:call-template name="mbFields"/>
            </CashPosition>
         </DataGroup>
      </PositionPMS>
   </xsl:template>
