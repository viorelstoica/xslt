<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns="http://www.odcgroup.com/FiPMS" xmlns:ns0="http://www.temenos.com/T24/event/Common/EventCommon" xmlns:b="http://www.temenos.com/T24/event/TTI/FinancialInstrumentYieldCurve" xmlns:batch="http://www.temenos.com/T24/event/TTI/BatchFinancialInstrumentYieldCurve" xmlns:c="http://www.temenos.com/T24/event/TTI/MultiFinancialInstrumentYieldCurve" xmlns:infra="http://www.odcgroup.com/InfraPMS" xmlns:multibatch="http://www.temenos.com/T24/event/TTI/BatchMultiFinancialInstrumentYieldCurve" exclude-result-prefixes="b c batch multibatch ns0" version="1.0">
   <xsl:output encoding="UTF-8" indent="yes" method="xml"/>
   <xsl:template match="c:MultiFinancialInstrumentYieldCurve">
      <xsl:apply-templates select="c:CurrentEvent/b:FinancialInstrumentYieldCurve"/>
   </xsl:template>
   <xsl:template match="batch:BatchFinancialInstrumentYieldCurve">
      <xsl:element xmlns="http://www.temenos.com/T24/event/TTI/BatchFinancialInstrumentYieldCurve" name="BatchFinancialInstrumentYieldCurve">
         <xsl:apply-templates select="b:FinancialInstrumentYieldCurve"/>
      </xsl:element>
   </xsl:template>
   <xsl:template match="multibatch:BatchMultiFinancialInstrumentYieldCurve">
      <xsl:element xmlns="http://www.temenos.com/T24/event/TTI/BatchMultiFinancialInstrumentYieldCurve" name="BatchMultiFinancialInstrumentYieldCurve">
         <xsl:apply-templates select="c:MultiFinancialInstrumentYieldCurve"/>
      </xsl:element>
   </xsl:template>
   <xsl:template match="b:FinancialInstrumentYieldCurve">
      <FiPMS>
         <xsl:attribute name="mode">INSUPD</xsl:attribute>
         <xsl:attribute name="output">
            <xsl:value-of select="concat('FinancialInstrumentYieldCurve',substring(b:refCcyDate,'1','5'))"/>
         </xsl:attribute>
         <DataGroup>
            <YieldCurve>
               <xsl:attribute name="description">
                  <xsl:value-of select="concat('FinancialInstrumentYieldCurve.xsl+', name(/*), '+', b:eventCommon/ns0:eventId, '+', b:eventCommon/ns0:creationTime)"/>
               </xsl:attribute>
               <xsl:attribute name="sequenceNumber">
                  <xsl:call-template name="calcSeqNum">
                     <xsl:with-param name="creationTime">
                        <xsl:value-of select="b:eventCommon/ns0:creationTime"/>
                     </xsl:with-param>
                  </xsl:call-template>
               </xsl:attribute>
               <xsl:call-template name="infra:code"/>
               <xsl:call-template name="infra:synonym"/>
               <xsl:call-template name="infra:shortName"/>
               <xsl:call-template name="infra:longName"/>
               <xsl:call-template name="infra:multilingualLongName"/>
               <xsl:call-template name="infra:notepad"/>
               <xsl:call-template name="infra:userDefinedField"/>
               <xsl:call-template name="infra:mbFields"/>
               <xsl:call-template name="active"/>
               <xsl:call-template name="euroConversionDate"/>
               <xsl:call-template name="euroConversionRule"/>
               <xsl:call-template name="euroNewInstrument"/>
               <xsl:call-template name="mainBusinessEntity"/>
               <xsl:call-template name="mainStockExchange"/>
               <xsl:call-template name="minimumQuantity"/>
               <xsl:call-template name="priceCalculationRule"/>
               <xsl:call-template name="provider"/>
               <xsl:call-template name="referenceCurrency"/>
               <xsl:call-template name="riskCountry"/>
               <xsl:call-template name="riskNature"/>
               <xsl:call-template name="roundLotQuantity"/>
               <xsl:call-template name="sector"/>
               <xsl:call-template name="stockExchange"/>
               <xsl:call-template name="subType"/>
               <xsl:call-template name="taxCountry"/>
               <xsl:call-template name="tickSize"/>
               <xsl:call-template name="tradable"/>
               <xsl:call-template name="type"/>
               <xsl:call-template name="valuationRule"/>
               <xsl:call-template name="default"/>
               <xsl:call-template name="InstrumentComposition"/>
               <xsl:call-template name="accrualRule"/>
               <xsl:call-template name="rateFrequencyUnit"/>
               <xsl:call-template name="rateFrequencyNumber"/>
               <xsl:call-template name="interpolationConvention"/>
               <xsl:call-template name="interpolationRule"/>
               <xsl:call-template name="interestRateConvention"/>
               <xsl:call-template name="referenceCurve"/>
               <xsl:call-template name="valueDays"/>
               <xsl:call-template name="businessDayConvention"/>
            </YieldCurve>
         </DataGroup>
      </FiPMS>
   </xsl:template>
