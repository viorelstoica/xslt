<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns="http://www.odcgroup.com/InfraPMS" xmlns:ns0="http://www.temenos.com/T24/event/Common/EventCommon" xmlns:b="http://www.temenos.com/T24/event/TTI/DepositCustomerUpdate" xmlns:batch="http://www.temenos.com/T24/event/TTI/BatchDepositCustomerUpdate" xmlns:c="http://www.temenos.com/T24/event/TTI/MultiDepositCustomerUpdate" xmlns:multibatch="http://www.temenos.com/T24/event/TTI/BatchMultiDepositCustomerUpdate" exclude-result-prefixes="b c batch multibatch ns0" version="1.0">
   <xsl:output encoding="UTF-8" indent="yes" method="xml"/>
   <xsl:template match="c:MultiDepositCustomerUpdate">
      <xsl:apply-templates select="c:CurrentEvent/b:DepositCustomerUpdate"/>
   </xsl:template>
   <xsl:template match="batch:BatchDepositCustomerUpdate">
      <xsl:element xmlns="http://www.temenos.com/T24/event/TTI/BatchDepositCustomerUpdate" name="BatchDepositCustomerUpdate">
         <xsl:apply-templates select="b:DepositCustomerUpdate"/>
      </xsl:element>
   </xsl:template>
   <xsl:template match="multibatch:BatchMultiDepositCustomerUpdate">
      <xsl:element xmlns="http://www.temenos.com/T24/event/TTI/BatchMultiDepositCustomerUpdate" name="BatchMultiDepositCustomerUpdate">
         <xsl:apply-templates select="c:MultiDepositCustomerUpdate"/>
      </xsl:element>
   </xsl:template>
   <xsl:template match="b:DepositCustomerUpdate">
      <InfraPMS>
         <xsl:attribute name="mode">INSUPD</xsl:attribute>
         <xsl:attribute name="output">
            <xsl:value-of select="concat('DepositCustomerUpdate',b:id)"/>
         </xsl:attribute>
         <DataGroup>
            <Deposit>
               <xsl:attribute name="description">
                  <xsl:value-of select="concat('DepositCustomerUpdate.xsl+', name(/*), '+', b:eventCommon/ns0:eventId, '+', b:eventCommon/ns0:creationTime)"/>
               </xsl:attribute>
               <xsl:attribute name="sequenceNumber">
                  <xsl:call-template name="calcSeqNum">
                     <xsl:with-param name="creationTime">
                        <xsl:value-of select="b:eventCommon/ns0:creationTime"/>
                     </xsl:with-param>
                  </xsl:call-template>
               </xsl:attribute>
               <xsl:call-template name="code"/>
               <xsl:call-template name="custodian"/>
               <xsl:call-template name="name"/>
               <xsl:call-template name="userDefinedField"/>
               <xsl:call-template name="mbFields"/>
            </Deposit>
         </DataGroup>
      </InfraPMS>
   </xsl:template>
