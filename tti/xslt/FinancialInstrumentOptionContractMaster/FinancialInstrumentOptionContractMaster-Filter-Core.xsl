	</xsl:template>
	<!-- END of protected area  -->
	<!-- Condition 1 -->
	<xsl:template match="b:FinancialInstrumentOptionContractMaster">
		<xsl:apply-templates select="self::b:FinancialInstrumentOptionContractMaster[($g_filterBySubAssetType='Y' and contains($list_SubAssetType_FinancialInstrumentOptionContractMaster,b:subAssetType)) or
